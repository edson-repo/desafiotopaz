	"item": [
		{
			"name": "01 - Salvar Link com Alias",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"var jsonData = pm.response.json();",
							"pm.collectionVariables.set('idLink', jsonData.id);",
							"pm.collectionVariables.set('alias', jsonData.alias);"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"urlOriginal\": \"{{urlOriginal}}\",\n  \"alias\": \"{{alias}}\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/link/salvar",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"link",
						"salvar"
					]
				}
			},
			"response": []
		},
